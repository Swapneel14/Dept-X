<% layout("/layouts/boilerplate") %>
<body>
    <div class="container mt-5" >
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h4 class="card-title mb-4 text-center">Update CGPA</h4>
                        <form action="/added/<%=student._id%>" method="POST">
                            <div class="mb-3">
                                <label for="cgpa" class="form-label">CGPA</label>
                                <input type="text" name="stu[cgpa]" id="cgpa" class="form-control" placeholder="Enter CGPA" required>
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-block">Submit</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
